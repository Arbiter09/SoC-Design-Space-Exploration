// Parametric direct-mapped cache — generated by Jinja2
// Parameters:
//   cache_size_kb : {{ cache_size_kb }}
//   memory_banks  : {{ memory_banks }}
//   bus_width     : {{ bus_width }}
//
// Derived (computed by generator.py):
//   addr_bits      : {{ addr_bits }}
//   index_bits     : {{ index_bits }}
//   tag_bits       : {{ tag_bits }}
//   words_per_bank : {{ words_per_bank }}
//   bank_sel_bits  : {{ bank_sel_bits }}

`timescale 1ns/1ps

module cache #(
    parameter CACHE_SIZE_KB  = {{ cache_size_kb }},
    parameter MEM_BANKS      = {{ memory_banks }},
    parameter WIDTH          = {{ bus_width }},
    parameter ADDR_BITS      = {{ addr_bits }},
    parameter INDEX_BITS     = {{ index_bits }},
    parameter TAG_BITS       = {{ tag_bits }},
    parameter WORDS_PER_BANK = {{ words_per_bank }},
    parameter BANK_SEL_BITS  = {{ bank_sel_bits }}
) (
    input  wire                    clk,
    input  wire                    rst_n,
    // CPU interface
    input  wire                    req_valid,
    input  wire                    req_we,
    input  wire [ADDR_BITS-1:0]    req_addr,
    input  wire [WIDTH-1:0]        req_wdata,
    output reg                     resp_valid,
    output reg  [WIDTH-1:0]        resp_rdata,
    output wire                    resp_hit
);

    // ---------------------------------------------------------------------------
    // Tag + valid store
    // ---------------------------------------------------------------------------
    reg [TAG_BITS-1:0]   tags  [0:WORDS_PER_BANK-1];
    reg                  valids[0:WORDS_PER_BANK-1];

    // ---------------------------------------------------------------------------
    // Data SRAM — one array per bank
    // ---------------------------------------------------------------------------
{% for b in range(memory_banks) %}
    reg [WIDTH-1:0] data_bank{{ b }} [0:WORDS_PER_BANK-1];
{% endfor %}

    // ---------------------------------------------------------------------------
    // Address decode
    // ---------------------------------------------------------------------------
    wire [INDEX_BITS-1:0]    index    = req_addr[INDEX_BITS-1:0];
    wire [TAG_BITS-1:0]      tag      = req_addr[ADDR_BITS-1:INDEX_BITS];
    wire [BANK_SEL_BITS-1:0] bank_sel = req_addr[INDEX_BITS +: BANK_SEL_BITS];

    assign resp_hit = req_valid & valids[index] & (tags[index] == tag);

    // ---------------------------------------------------------------------------
    // Read / write FSM
    // ---------------------------------------------------------------------------
    integer i;
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            resp_valid <= 1'b0;
            resp_rdata <= {WIDTH{1'b0}};
            for (i = 0; i < WORDS_PER_BANK; i = i + 1) begin
                valids[i] <= 1'b0;
                tags  [i] <= {TAG_BITS{1'b0}};
            end
        end else begin
            resp_valid <= req_valid;
            if (req_valid && req_we) begin
                tags  [index] <= tag;
                valids[index] <= 1'b1;
{% for b in range(memory_banks) %}
{% if b == 0 %}
                if (bank_sel == {{ bank_sel_bits }}'d{{ b }})
{% else %}
                else if (bank_sel == {{ bank_sel_bits }}'d{{ b }})
{% endif %}
                    data_bank{{ b }}[index] <= req_wdata;
{% endfor %}
            end else if (req_valid && resp_hit) begin
                resp_rdata <= {WIDTH{1'b0}};
{% for b in range(memory_banks) %}
{% if b == 0 %}
                if (bank_sel == {{ bank_sel_bits }}'d{{ b }})
{% else %}
                else if (bank_sel == {{ bank_sel_bits }}'d{{ b }})
{% endif %}
                    resp_rdata <= data_bank{{ b }}[index];
{% endfor %}
            end else begin
                resp_rdata <= {WIDTH{1'b0}};
            end
        end
    end

endmodule
