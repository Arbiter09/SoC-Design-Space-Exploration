// Parametric pipeline module — generated by Jinja2
// Parameters:
//   pipeline_stages : {{ pipeline_stages }}
//   alu_units       : {{ alu_units }}
//   bus_width       : {{ bus_width }}

`timescale 1ns/1ps

module pipeline #(
    parameter STAGES    = {{ pipeline_stages }},
    parameter ALU_UNITS = {{ alu_units }},
    parameter WIDTH     = {{ bus_width }}
) (
    input  wire             clk,
    input  wire             rst_n,
    input  wire             valid_in,
    input  wire [WIDTH-1:0] data_in,
    input  wire [3:0]       opcode_in,
    output wire             valid_out,
    output wire [WIDTH-1:0] result_out,
    output wire             stall_out
);

    // ---------------------------------------------------------------------------
    // Stage registers — one set per pipeline stage
    // ---------------------------------------------------------------------------
    reg [WIDTH-1:0] stage_data  [0:STAGES-1];
    reg             stage_valid [0:STAGES-1];
    reg [3:0]       stage_opcode[0:STAGES-1];

    // Simple stall: assert when all stages are full and a new datum arrives
    wire pipeline_full;
    assign pipeline_full = stage_valid[STAGES-1] & valid_in;
    assign stall_out     = pipeline_full;

    // ---------------------------------------------------------------------------
    // Pipeline advance
    // ---------------------------------------------------------------------------
    integer s;
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            for (s = 0; s < STAGES; s = s + 1) begin
                stage_data  [s] <= {WIDTH{1'b0}};
                stage_valid [s] <= 1'b0;
                stage_opcode[s] <= 4'b0;
            end
        end else if (!pipeline_full) begin
            // Shift stages
            stage_data  [0] <= data_in;
            stage_valid [0] <= valid_in;
            stage_opcode[0] <= opcode_in;
            for (s = 1; s < STAGES; s = s + 1) begin
                stage_data  [s] <= stage_data  [s-1];
                stage_valid [s] <= stage_valid [s-1];
                stage_opcode[s] <= stage_opcode[s-1];
            end
        end
    end

    // ---------------------------------------------------------------------------
    // ALU units (instantiated but simplified for synthesis)
    // ---------------------------------------------------------------------------
{% for i in range(alu_units) %}
    wire [WIDTH-1:0] alu{{ i }}_result;
    alu_unit #(.WIDTH(WIDTH)) u_alu{{ i }} (
        .a      (stage_data[STAGES > 1 ? STAGES/2 : 0]),
        .b      (stage_data[0]),
        .opcode (stage_opcode[STAGES > 1 ? STAGES/2 : 0]),
        .result (alu{{ i }}_result)
    );
{% endfor %}

    // Output comes from the last stage; use ALU 0 result when stages > 1
    assign valid_out  = stage_valid[STAGES-1];
{% if alu_units > 0 %}
    assign result_out = (STAGES > 1) ? alu0_result : stage_data[STAGES-1];
{% else %}
    assign result_out = stage_data[STAGES-1];
{% endif %}

endmodule


// ---------------------------------------------------------------------------
// Simple ALU — synthesizes cleanly with Yosys
// ---------------------------------------------------------------------------
module alu_unit #(
    parameter WIDTH = 32
) (
    input  wire [WIDTH-1:0] a,
    input  wire [WIDTH-1:0] b,
    input  wire [3:0]       opcode,
    output reg  [WIDTH-1:0] result
);
    always @(*) begin
        case (opcode)
            4'h0: result = a + b;
            4'h1: result = a - b;
            4'h2: result = a & b;
            4'h3: result = a | b;
            4'h4: result = a ^ b;
            4'h5: result = a << b[4:0];
            4'h6: result = a >> b[4:0];
            4'h7: result = (a < b) ? {{WIDTH-1{1'b0}}, 1'b1} : {WIDTH{1'b0}};
            default: result = {WIDTH{1'b0}};
        endcase
    end
endmodule
