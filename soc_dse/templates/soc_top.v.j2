// Top-level SoC integration — generated by Jinja2
// Instantiates pipeline and cache with matched port declarations.
// Parameters:
//   pipeline_stages : {{ pipeline_stages }}
//   alu_units       : {{ alu_units }}
//   cache_size_kb   : {{ cache_size_kb }}
//   memory_banks    : {{ memory_banks }}
//   bus_width       : {{ bus_width }}
//
// Derived:
//   addr_bits : {{ addr_bits }}

`timescale 1ns/1ps

module soc_top #(
    parameter STAGES         = {{ pipeline_stages }},
    parameter ALU_UNITS      = {{ alu_units }},
    parameter CACHE_SIZE_KB  = {{ cache_size_kb }},
    parameter MEM_BANKS      = {{ memory_banks }},
    parameter WIDTH          = {{ bus_width }},
    parameter ADDR_BITS      = {{ addr_bits }}
) (
    input  wire             clk,
    input  wire             rst_n,

    // External CPU instruction feed
    input  wire             cpu_valid,
    input  wire [WIDTH-1:0] cpu_data,
    input  wire [3:0]       cpu_opcode,

    // External memory request
    input  wire             mem_req_valid,
    input  wire             mem_req_we,
    input  wire [ADDR_BITS-1:0] mem_req_addr,
    input  wire [WIDTH-1:0] mem_req_wdata,

    // Outputs
    output wire             pipe_valid_out,
    output wire [WIDTH-1:0] pipe_result_out,
    output wire             pipe_stall,
    output wire             cache_resp_valid,
    output wire [WIDTH-1:0] cache_resp_rdata,
    output wire             cache_resp_hit
);

    // ---------------------------------------------------------------------------
    // Pipeline instance
    // Port list must match pipeline.v exactly:
    //   clk, rst_n, valid_in, data_in, opcode_in,
    //   valid_out, result_out, stall_out
    // ---------------------------------------------------------------------------
    pipeline #(
        .STAGES    (STAGES),
        .ALU_UNITS (ALU_UNITS),
        .WIDTH     (WIDTH)
    ) u_pipeline (
        .clk        (clk),
        .rst_n      (rst_n),
        .valid_in   (cpu_valid),
        .data_in    (cpu_data),
        .opcode_in  (cpu_opcode),
        .valid_out  (pipe_valid_out),
        .result_out (pipe_result_out),
        .stall_out  (pipe_stall)
    );

    // ---------------------------------------------------------------------------
    // Cache instance
    // Port list must match cache.v exactly:
    //   clk, rst_n, req_valid, req_we, req_addr, req_wdata,
    //   resp_valid, resp_rdata, resp_hit
    // ---------------------------------------------------------------------------
    cache #(
        .CACHE_SIZE_KB  (CACHE_SIZE_KB),
        .MEM_BANKS      (MEM_BANKS),
        .WIDTH          (WIDTH),
        .ADDR_BITS      ({{ addr_bits }}),
        .INDEX_BITS     ({{ index_bits }}),
        .TAG_BITS       ({{ tag_bits }}),
        .WORDS_PER_BANK ({{ words_per_bank }}),
        .BANK_SEL_BITS  ({{ bank_sel_bits }})
    ) u_cache (
        .clk        (clk),
        .rst_n      (rst_n),
        .req_valid  (mem_req_valid),
        .req_we     (mem_req_we),
        .req_addr   (mem_req_addr),
        .req_wdata  (mem_req_wdata),
        .resp_valid (cache_resp_valid),
        .resp_rdata (cache_resp_rdata),
        .resp_hit   (cache_resp_hit)
    );

endmodule
